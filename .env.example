# Project Synapse MCP Server — Environment Configuration (example)
#
# Only variables this template lists are actually read by code in src/.
# Cruft variables that older templates carried (KNOWLEDGE_GRAPH_PATH,
# BACKUP_*, MCP_MAX_CONNECTIONS, ZETTEL_ID_FORMAT, CACHE_TTL, BATCH_SIZE,
# MAX_CONCURRENT_PROCESSING, LOG_FILE_PATH, GRAPH_QUERY_TIMEOUT) were
# confirmed unused on 2026-05-23 and dropped.

# ---------------------------------------------------------------------------
# Neo4j
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=synapse_password
NEO4J_DATABASE=synapse

# ---------------------------------------------------------------------------
# Extraction mode
# ---------------------------------------------------------------------------
# "montague" = local NLP only, "llm" = LLM-driven extraction
EXTRACTION_PROVIDER=llm

# ---------------------------------------------------------------------------
# LLM Provider Abstraction (extraction + insight synthesis)
# Supported: ollama | minimax | openrouter
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama
# LLM_MODEL=
# LLM_TIMEOUT=120              # general per-request timeout in seconds

# Per-job overrides — extraction stays cheap/local; insight synthesis can
# point at a sharper cloud model since it runs far less often.
# EXTRACTION_LLM_PROVIDER=ollama
# EXTRACTION_LLM_MODEL=gemma4:latest
# EXTRACTION_LLM_TIMEOUT=120
# EXTRACTION_MAX_TOKENS=16384

INSIGHT_LLM_ENABLED=true
# INSIGHT_LLM_PROVIDER=minimax
# INSIGHT_LLM_MODEL=MiniMax-M2.7-highspeed
# INSIGHT_LLM_MAX_TOKENS=2048
# 230s lands inside the typical 300s MCP client tool-call wall.
# Cron callers using scripts/generate_insights.py bypass MCP and can go higher.
# INSIGHT_LLM_TIMEOUT=230

# On-demand persistence — write insights to Neo4j (as Zettel nodes) and
# to a timestamped JSON+MD pair so cron jobs can pick them up later.
INSIGHT_PERSIST_ON_DEMAND=true
INSIGHT_WRITE_FILE=true
INSIGHTS_OUTPUT_DIR=./data/insights

# MiniMax (https://platform.minimax.io/docs/token-plan/other-tools)
# MINIMAX_API_KEY=sk-cp-...
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7-highspeed

# OpenRouter (https://openrouter.ai/docs/api-reference/chat-completion)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/your-project
# OPENROUTER_X_TITLE=project-synapse-mcp

# ---------------------------------------------------------------------------
# Autonomous insight loop (separate from on-demand generate_insights)
# ---------------------------------------------------------------------------
SYNAPSE_AUTONOMOUS_INSIGHTS=off
PATTERN_DETECTION_INTERVAL=300
# SYNAPSE_INSIGHT_STARTUP_DELAY=120

# ---------------------------------------------------------------------------
# Embeddings (kept local)
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=2560
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
OLLAMA_EXTRACTION_MODEL=gemma4:latest
OLLAMA_TIMEOUT=300
# OLLAMA_NUM_CTX=131072
# OLLAMA_THINK=true

# ---------------------------------------------------------------------------
# Zettelkasten / batching
# ---------------------------------------------------------------------------
LINK_THRESHOLD=0.7
INSIGHT_CONFIDENCE_THRESHOLD=0.8
SEMANTIC_BATCH_SIZE=50

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Wiki (LLM-WIKI) integration
# ---------------------------------------------------------------------------
WIKI_VAULT_PATH=/path/to/your/obsidian-vault
WIKI_GITHUB_REPO=https://github.com/user/wiki-repo
