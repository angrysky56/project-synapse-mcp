# Project Synapse MCP Server Environment Configuration

# Neo4j Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=synapse_password
NEO4J_DATABASE=synapse

# AI Model Configuration
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model Settings (local only — no paid APIs)
# EMBEDDING_PROVIDER: "sentence-transformers" (default) or "ollama"
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_DIMENSION=768
# Ollama embedding (used when EMBEDDING_PROVIDER=ollama)
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=2560
OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# Zettelkasten Configuration
ZETTEL_ID_FORMAT=timestamp
LINK_THRESHOLD=0.7
INSIGHT_CONFIDENCE_THRESHOLD=0.8

# Knowledge Processing Settings
MAX_CONCURRENT_PROCESSING=3
BATCH_SIZE=100
CACHE_TTL=3600

# Extraction Provider: "montague" (default) or "llm" (LLM-driven extraction)
EXTRACTION_PROVIDER=llm
OLLAMA_EXTRACTION_MODEL=gemma4:latest
OLLAMA_TIMEOUT=300

# ---------------------------------------------------------------------------
# LLM Provider Abstraction
# ---------------------------------------------------------------------------
# Picks which provider the LLM-driven extractor AND the insight synthesis
# layer talk to. Per-job overrides (EXTRACTION_LLM_PROVIDER /
# INSIGHT_LLM_PROVIDER) let you split local-vs-cloud by workload.
#
# Supported: ollama | minimax | openrouter
LLM_PROVIDER=ollama
# LLM_MODEL=             # provider-default if blank

# --- Extraction (high volume, can stay local) -----------------------------
# EXTRACTION_LLM_PROVIDER=ollama
# EXTRACTION_LLM_MODEL=gemma4:latest
# EXTRACTION_MAX_TOKENS=16384

# --- Insight synthesis (low volume, benefits from a sharper cloud model) --
# INSIGHT_LLM_ENABLED=true       # set "false" to keep templated insights only
# INSIGHT_LLM_PROVIDER=minimax
# INSIGHT_LLM_MODEL=MiniMax-M2.7-highspeed
# INSIGHT_LLM_MAX_TOKENS=2048
# INSIGHT_LLM_TIMEOUT=60

# --- MiniMax (OpenAI-compatible) ------------------------------------------
# Get a Token Plan key (sk-cp-...): https://platform.minimax.io/user-center/payment/token-plan
# MINIMAX_API_KEY=sk-cp-...
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7-highspeed

# --- OpenRouter -----------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://github.com/angrysky56/project-synapse-mcp
# OPENROUTER_X_TITLE=project-synapse-mcp

# Autonomous Engine Kill-Switch: "off" (default) or "on"
SYNAPSE_AUTONOMOUS_INSIGHTS=off

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PATH=./data/synapse.log

# MCP Server Settings
MCP_SERVER_NAME=project-synapse
MCP_SERVER_VERSION=0.1.0
MCP_MAX_CONNECTIONS=10

# Data Persistence
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph
CACHE_PATH=./data/cache
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24

# Performance Tuning
SEMANTIC_BATCH_SIZE=50
GRAPH_QUERY_TIMEOUT=30
PATTERN_DETECTION_INTERVAL=300

# Wiki (LLM-WIKI) Integration
WIKI_VAULT_PATH=/path/to/your/obsidian-vault
WIKI_GITHUB_REPO=https://github.com/user/wiki-repo
